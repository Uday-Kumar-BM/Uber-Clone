# Node.js environment (development, production, test)
NODE_ENV=development
PORT=5000

# Database configuration
# Use DB_TYPE to specify 'postgres', 'mysql', 'sqlite', or 'mssql'
DB_TYPE=postgres
# Example PostgreSQL URI: postgres://user:password@host:port/database
# Example MySQL URI: mysql://user:password@host:port/database
# Example SQLite URI: sqlite://./database.sqlite (relative path)
DATABASE_URI=postgres://user:password@localhost:5432/ridesharing_db

# JWT Secret for authentication tokens
JWT_SECRET=your_jwt_secret_key_here_please_make_it_long_and_random
JWT_EXPIRES_IN=15m

# Refresh Token Secret (if implementing refresh tokens)
JWT_REFRESH_SECRET=your_refresh_token_secret_key_here_please_make_it_long_and_random
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt salt rounds for password hashing (cost factor)
BCRYPT_SALT_ROUNDS=12

# Rate limiting (requests per windowMs)
RATE_LIMIT_WINDOW_MS=15 # in minutes
RATE_LIMIT_MAX=100

# CORS (Comma-separated list of allowed origins, or '*' for all)
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
